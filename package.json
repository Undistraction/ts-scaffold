{
  "name": "ts-scaffold",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:eslint": "eslint --fix .",
    "lint:prettier": "prettier --write .",
    "test:unit": "vitest",
    "test:unit:no-watch": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "security:audit": "audit-ci --config ./audit-ci.jsonc",
    "types:check": "tsc --noEmit",
    "db:generate": "npx drizzle-kit generate",
    "db:push": "npx drizzle-kit push",
    "db:push:test": "ENV_FILE=.env.test npx drizzle-kit push",
    "db:studio": "npx drizzle-kit studio",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -o CHANGELOG.md",
    "husky:actions": "npm run security:audit && npx lint-staged && npm run types:check && npm run test:unit:no-watch",
    "prepare": "husky && git tag v0.0.0 2>/dev/null || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@next/eslint-plugin-next": "^16.1.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/eslint-plugin-query": "5.91.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "25.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/eslint-plugin": "1.6.9",
    "audit-ci": "^7.1.0",
    "conventional-changelog": "^7.2.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "0.31.9",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-check-file": "3.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "2.9.0",
    "eslint-plugin-prefer-arrow-functions": "3.9.1",
    "eslint-plugin-react-hooks": "7.1.0-canary-e8c63626-20260213",
    "eslint-plugin-unicorn": "63.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "husky": "9.1.7",
    "jiti": "2.6.1",
    "jsdom": "28.1.0",
    "lint-staged": "16.2.7",
    "postcss": "^8.5.8",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.0",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-query": "5.90.21",
    "drizzle-orm": "0.45.1",
    "lucide-react": "0.576.0",
    "next": "^16.1.6",
    "next-safe-action": "^8.1.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  }
}
