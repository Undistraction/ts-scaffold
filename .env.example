# Neon Postgres connection string (https://console.neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Sentry (https://sentry.io/settings/)
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=sntrys_... (https://sentry.io/settings/auth-tokens/)

# Clerk authentication (https://dashboard.clerk.com/last-active?path=api-keys)
# Optional — without these, Clerk runs in keyless mode with temporary dev keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
