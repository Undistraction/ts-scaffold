# ──────────────────────────────────────────────
# .env — Shared config (all environments)
# ──────────────────────────────────────────────
# Sentry project identifiers (from https://sentry.io/settings/)
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project

# Sentry DSN — get from https://sentry.io/settings/projects/YOUR_PROJECT/keys/
# Public key, safe to share — it ships in client bundles.
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ──────────────────────────────────────────────
# .env.development / .env.test — Per-environment
# ──────────────────────────────────────────────
# Neon Postgres connection string (https://console.neon.tech)
# Use separate databases for dev and test — set in .env.development and .env.test respectively.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ──────────────────────────────────────────────
# .env.sentry-build-plugin — Build secret (do NOT commit)
# ──────────────────────────────────────────────
# SENTRY_AUTH_TOKEN=sntrys_...


# Clerk authentication (https://dashboard.clerk.com/last-active?path=api-keys)
# Optional — without these, Clerk runs in keyless mode with temporary dev keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...


# ──────────────────────────────────────────────
# .env.test — Test-specific
# ──────────────────────────────────────────────
# E2E test user — create in Clerk dashboard, then set credentials here.
E2E_CLERK_USER_EMAIL=
E2E_CLERK_USER_PASSWORD=
