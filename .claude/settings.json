{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(source ~/.bashrc)",
      "Bash(npm view @tanstack/eslint-plugin-query versions --json)",
      "Bash(npm view @tanstack/eslint-plugin-query@5.91.4 peerDependencies --json)",
      "Bash(npx eslint --max-warnings=0 src/)",
      "Bash(npm install @tanstack/react-query lucide-react)",
      "Bash(npx eslint eslint.config.ts)",
      "Bash(npm ls eslint)",
      "Bash(npx prettier --check \".github/**/*.yml\")",
      "Bash(npx prettier --write \".github/**/*.yml\")",
      "Bash(npx vitest run --reporter=verbose)",
      "Bash(source ~/.nvm/nvm.sh)",
      "Bash(npx eslint src/components/ui/button.stories.tsx .storybook/main.ts .storybook/preview.ts)",
      "Bash(npx eslint src/components/ui/button.stories.tsx)",
      "Bash(npx vitest run src/components/ui/button.test.tsx)",
      "Bash(npm view @storybook/addon-vitest versions --json)",
      "Bash(npm view @storybook/addon-vitest@10 versions --json)",
      "Bash(npm install -D @storybook/addon-vitest@10)",
      "Bash(npm install -D @vitest/browser --legacy-peer-deps)",
      "Bash(npm ls @testing-library/dom)",
      "Bash(npx vitest run --project ui)",
      "Bash(npx vitest --help)",
      "Bash(npx vitest run --project unit)",
      "Bash(npm install -D @vitest/browser@4.0.18)",
      "Bash(npm ls @vitest/browser-playwright)",
      "Bash(npm install -D @vitest/browser-playwright@4.0.18)",
      "Bash(node --trace-warnings node_modules/.bin/vitest run --project ui)",
      "Bash(rg -c 'optionalEnvToBoolean' /Users/pedr/Documents/Code/Repositories/ts-scaffold/node_modules/storybook/ --include '*.js')"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_FILE_PATH\" in */package-lock.json|*.env|*.env.*|*/CHANGELOG.md|*/.next/*) echo \"BLOCK: This is a generated or sensitive file. Do not edit it directly.\" >&2; exit 2;; esac"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_FILE_PATH\" in *.ts|*.tsx|*.js|*.jsx) npx eslint --fix \"$CLAUDE_FILE_PATH\";; esac"
          },
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATH\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm run types:check"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "Notion@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  }
}
