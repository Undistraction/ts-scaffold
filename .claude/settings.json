{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(npm install --save-dev prettier-plugin-tailwindcss)",
      "Bash(source ~/.bashrc)",
      "Bash(npm install --save-dev eslint-plugin-unused-imports eslint-plugin-unicorn eslint-plugin-prefer-arrow-functions eslint-plugin-react @vitest/eslint-plugin eslint-plugin-playwright)",
      "Bash(npm install --save-dev @tanstack/eslint-plugin-query)",
      "Bash(npm view @tanstack/eslint-plugin-query versions --json)",
      "Bash(npm view @tanstack/eslint-plugin-query@5.91.4 peerDependencies --json)",
      "Bash(npm install -D eslint-plugin-check-file)",
      "Bash(npx eslint --max-warnings=0 src/)",
      "Bash(npm install @tanstack/react-query lucide-react)",
      "Bash(npx eslint eslint.config.ts)",
      "Bash(npm ls eslint)",
      "Bash(npm install eslint@9)",
      "Bash(npm install --save-dev @tanstack/eslint-plugin-query --legacy-peer-deps)",
      "Bash(npx prettier --check \".github/**/*.yml\")",
      "Bash(npx prettier --write \".github/**/*.yml\")"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_FILE_PATH\" in */package-lock.json|*.env|*.env.*|*/CHANGELOG.md|*/.next/*) echo \"BLOCK: This is a generated or sensitive file. Do not edit it directly.\" >&2; exit 2;; esac"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_FILE_PATH\" in *.ts|*.tsx|*.js|*.jsx) npx eslint --fix \"$CLAUDE_FILE_PATH\";; esac"
          },
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATH\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm run types:check"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "Notion@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  }
}
